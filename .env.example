# Environment Configuration
ENVIRONMENT=local  # local, staging, production

# CORS Configuration
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# JWT Configuration
SECRET_KEY=your-super-secret-key-here-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Database Configuration (for application connection)
# Note: Docker database credentials are configured separately in .env.docker
POSTGRES_SERVER=localhost
POSTGRES_PORT=5442
POSTGRES_USER=fastapi_user
POSTGRES_PASSWORD=fastapi_password
POSTGRES_DB=fastapi_db

# Alembic Database URL (used by alembic.ini)
DATABASE_URL=postgresql+psycopg://fastapi_user:fastapi_password@localhost:5442/fastapi_db

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/login/google/callback

# First Superuser Configuration
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=superuserpassword123